{
   "semi": false,
   "singleQuote": true,
   "trailingComma": "all",
   "tabWidth": 3,
   "printWidth": 120,
   "bracketSpacing": true,
   "arrowParens": "avoid",
   "endOfLine": "lf",
   "plugins": ["@trivago/prettier-plugin-sort-imports"],
   "importOrder": ["^react$", "^react-dom", "<THIRD_PARTY_MODULES>", "^@/", "^[./]"],
   "importOrderSeparation": true,
   "importOrderSortSpecifiers": true
}
