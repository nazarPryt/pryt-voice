{
   "productName": "Pryt-Voice",
   "version": "2.0.0",
   "identifier": "com.pryt.voice",
   "build": {
      "frontendDist": "../dist",
      "devUrl": "http://localhost:1420",
      "beforeDevCommand": "bun run vite:dev",
      "beforeBuildCommand": "bun run vite:build"
   },
   "app": {
      "windows": [
         {
            "title": "Pryt Voice",
            "width": 800,
            "height": 600,
            "minWidth": 400,
            "minHeight": 400,
            "backgroundColor": "#1a1a2e"
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": ["deb"],
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "resources": {
         "../whisper/whisper.cpp/build/bin/whisper-cli": "whisper/whisper-cli",
         "../whisper/models/ggml-base.en.bin": "whisper/ggml-base.en.bin"
      },
      "linux": {
         "deb": {
            "depends": []
         }
      }
   }
}
